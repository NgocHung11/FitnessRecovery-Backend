{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=fitness_recovery;Username=postgres;Password=YOUR_LOCAL_PASSWORD_HERE",
    "RedisConnection": "localhost:6379"
  },
  "Jwt": {
    "Key": "YOUR_JWT_KEY_HERE",
    "Issuer": "FitnessRecovery",
    "Audience": "FitnessRecoveryApi",
    "DurationInMinutes": "60",
    "RefreshTokenDurationInDays": "7"
  }
}
